# GitHub REST API
# Optional but strongly recommended: without a token, GitHub limits you to
# 60 requests/hour per IP. With a token (no scopes needed for public data),
# you get 5,000 requests/hour.
# Create one at: https://github.com/settings/tokens
# This is read server-side only (in app/api/github/*) and is never sent
# to the browser.
GITHUB_TOKEN=

# Base URL for the GitHub REST API (rarely needs changing).
# NOTE: renamed from NEXT_PUBLIC_GITHUB_API_URL in Phase 2 — it's no longer
# prefixed with NEXT_PUBLIC_ because it's only ever read on the server now
# (our Next.js API routes proxy GitHub, the browser never calls GitHub directly).
GITHUB_API_URL=https://api.github.com
